/**
 * @file    protocol.c
 * @brief   自定义串口协议实现
 *
 * ISR 地址过滤: 收到地址字节后立即检查, 不匹配则清空缓冲区 (硬件级过滤)
 * 主循环处理: 帧完整 → XOR 校验 → 命令分发 → 回复
 */

#include "protocol.h"
#include "STC8G_H_GPIO.h"
#include "STC8G_H_Timer.h"
#include "i2c_cmd.h"
#include <string.h>

/* ========== 外部变量 ========== */
extern bit start_discharge_req, stop_discharge_req;
extern bit start_charge_req, stop_charge_req;
extern void SetChargeParamsByBatteryType(void);

/* ========== Ring Buffer ========== */
#define RB_SIZE    256
static unsigned char  rb[RB_SIZE];
static volatile unsigned char rb_wr;       /* ISR 写指针 */
static volatile unsigned char rb_count;    /* ISR 字节计数 */
static volatile bit      rb_pkt_ready;     /* 帧完整标志 */
static unsigned char     mb_addr;          /* 本机地址 */
static unsigned char     tx_buf[128];

/* ========== TX 标志 ========== */
static volatile bit tx_busy;  /* 主循环正在发送 */

static void pt_putc(unsigned char c) {
    tx_busy = 1;   /* 告诉 ISR: 主循环在发, 别碰 TI */
    SBUF = c;
    while (!TI);   /* 等 TI 硬件置位 */
    TI = 0;
    tx_busy = 0;   /* 发完了 */
}

static void send_buf(const unsigned char *b, unsigned char n) {
    unsigned char i; for (i = 0; i < n; i++) pt_putc(b[i]);
}

/* ========== 寄存器读写 ========== */
static unsigned char write_reg(unsigned short a, unsigned short v)
{
    switch (a) {
        case 0x00: /* 命令寄存器 */
            switch (v) {
                case PCMD_START_DISCHARGE: start_discharge_req = 1; break;
                case PCMD_STOP_DISCHARGE:  stop_discharge_req  = 1; break;
                case PCMD_START_CHARGE:    start_charge_req    = 1; break;
                case PCMD_STOP_CHARGE:     stop_charge_req     = 1; break;
                case PCMD_EMERGENCY_STOP:  stop_charge_req = 1; stop_discharge_req = 1; break;
                default: return 0;
            } return 1;
        case REG_SET_OVERC_PROT:  overchargeProtectVolt = v; return 1;
        case REG_SET_OVERD_PROT:  overdischargeProtectVolt = v; return 1;
        case REG_SET_CYCLE_NUM:   cycleDischargeNum = (unsigned char)v; return 1;
        case REG_SET_CHG_VOLT:
            chargeVoltSet = (unsigned char)v;
            CHG_VOLT_SET_1 = (chargeVoltSet & 1) ? 1 : 0;
            CHG_VOLT_SET_2 = (chargeVoltSet & 2) ? 1 : 0;
            return 1;
        case REG_SET_CHG_CURRENT: chargeCurrentSet = (unsigned char)v; CHG_CURRENT_SET = 1; return 1;
        case REG_SET_BAT_TYPE: batteryType = (unsigned char)v; SetChargeParamsByBatteryType(); return 1;
    }
    return 0;
}

static unsigned short read_reg(unsigned short a)
{
    switch (a) {
        case 0x00:                return 0;
        case REG_STATUS_CHARGE:   return alarmOvercharge;
        case REG_STATUS_DISCHARGE:return alarmOverdischarge;
        case REG_CHARGE_MAH:      return curChargeMAH;
        case REG_DISCHARGE_MAH:   return curDischargeMAH;
        case REG_BAT_VOLT:        return curBatVolt;
        case REG_CHARGE_CURRENT:  return curChargeCurrentMA;
        case REG_DISCHARGE_CURRENT:return curDischargeCurrentMA;
        case REG_OVERC_PROT:      return overchargeProtectVolt;
        case REG_OVERD_PROT:      return overdischargeProtectVolt;
        case REG_CYCLE_NUM:       return curCycleNum;
        case REG_DEVICE_ID:       return 0x0101;
        case REG_SET_OVERC_PROT:  return overchargeProtectVolt;
        case REG_SET_OVERD_PROT:  return overdischargeProtectVolt;
        case REG_SET_CYCLE_NUM:   return cycleDischargeNum;
        case REG_SET_CHG_VOLT:    return chargeVoltSet;
        case REG_SET_CHG_CURRENT: return chargeCurrentSet;
        case REG_SET_BAT_TYPE:    return batteryType;
        default:
            if (a >= REG_CYCLE_DISCH_BASE && a < REG_CYCLE_DISCH_BASE + 10)
                return cycleDischargeEndMAH[a - REG_CYCLE_DISCH_BASE];
            if (a >= REG_CYCLE_CHG_BASE && a < REG_CYCLE_CHG_BASE + 10)
                return cycleChargeEndMAH[a - REG_CYCLE_CHG_BASE];
            return 0;
    }
}


/* ========== 帧状态机 (ISR 内) ========== */
static unsigned char fsm_state;   /* 0=等帧头, 1=收帧头, 2=收数据, 3=丢弃 */
static unsigned char fsm_pos;     /* 当前帧内位置 (1-based) */
static unsigned char fsm_addr;    /* 保存的帧地址 */
static unsigned char fsm_len;     /* 期望帧长 (3+hdr_len+1) */

/* ========== UART1 ISR: 字节接收 + 硬件级地址过滤 ========== */
void UART1_ISR(void) interrupt 4
{
    unsigned char ch;

    if (RI) {
        RI = 0;
        ch = SBUF;
        fsm_pos++;

        switch (fsm_state) {

        case 0: /* 等帧头: 这个字节是地址 */
            fsm_addr = ch;
            fsm_pos = 1;
            if (ch == mb_addr || ch == 0) {
                /* 地址匹配! 开始接收 */
                fsm_state = 1;
                rb[rb_wr++] = ch;
                if (rb_wr >= RB_SIZE) rb_wr = 0;
                rb_count = 1;
            } else {
                /* 地址不匹配, 进入丢弃模式 */
                fsm_state = 3;
                fsm_len = 0;  /* 还没收到长度, 先等 */
            }
            break;

        case 1: /* 收帧头 (cmd + len) 或收数据 */
            rb[rb_wr++] = ch;
            if (rb_wr >= RB_SIZE) rb_wr = 0;
            if (rb_count < RB_SIZE) rb_count++;
            else { rb_count = RB_SIZE; }

            if (fsm_pos == 3) {
                /* 收到长度字节 */
                fsm_len = 3 + ch + 1;  /* 帧头 + 数据 + 校验 */
            }
            if (fsm_pos >= fsm_len) {
                /* 帧收齐 */
                rb_pkt_ready = 1;
                fsm_state = 0;
            }
            break;

        case 3: /* 丢弃模式: 等待帧结束 */
            if (fsm_pos == 3) {
                fsm_len = 3 + ch + 1;  /* 知道帧长了 */
            }
            if (fsm_pos >= fsm_len) {
                fsm_state = 0;  /* 丢弃完毕, 等下一帧 */
            }
            break;
        }
    }

    if (TI && !tx_busy) {
        TI = 0;
    }
}


/* ========== 主循环调用: 处理完整帧 ========== */
void Protocol_Poll(void)
{
    unsigned char i, cmd, len, status, data_len, chk;
    unsigned short addr, cnt, val;

    if (!rb_pkt_ready) return;

    /* 从 ring buffer 取出帧 */
    {
        unsigned char start = (rb_wr >= rb_count) ? (rb_wr - rb_count) : (RB_SIZE + rb_wr - rb_count);
        for (i = 0; i < rb_count; i++) {
            tx_buf[i] = rb[(start + i) % RB_SIZE];
        }
    }
    i = rb_count;      /* 帧长度 */
    rb_count = 0;
    rb_pkt_ready = 0;

    if (i < 4) return;  /* 最小帧: [ADDR][CMD][0][CHK] = 4字节 */

    /* 计算期望长度并验证 */
    len = tx_buf[2];  /* 数据长度 */
    if (i != 4 + len) return;  /* 帧长度不匹配 */

    /* XOR 校验 */
    chk = 0;
    { unsigned char n; for (n = 0; n < i - 1; n++) chk ^= tx_buf[n]; }
    if (chk != tx_buf[i - 1]) return;

    /* 解析 */
    cmd  = tx_buf[1];
    len  = tx_buf[2];  /* 数据长度 */

    /* ---- 广播 ---- */
    if (tx_buf[0] == 0) {
        if (cmd == PCMD_WRITE && len == 4) {
            addr = ((unsigned short)tx_buf[3] << 8) | tx_buf[4];
            val  = ((unsigned short)tx_buf[5] << 8) | tx_buf[6];
            write_reg(addr, val);
        }
        return;
    }

    /* ---- 单播 ---- */
    switch (cmd) {

    case PCMD_BATCH_READ:
    case PCMD_READ:
        if (len < 3) { status = PST_ERR; data_len = 0; break; }
        addr = ((unsigned short)tx_buf[3] << 8) | tx_buf[4];
        cnt  = tx_buf[5];
        if (cnt == 0 || cnt > 64) { status = PST_ERR; data_len = 0; break; }

        /* 构建响应: [ADDR][CMD|0x80][OK][LEN=CNT*2][VAL....][CHK] */
        status = PST_OK;
        data_len = cnt * 2;
        tx_buf[0] = mb_addr;
        tx_buf[1] = cmd | 0x80;
        tx_buf[2] = status;
        tx_buf[3] = data_len;
        for (i = 0; i < cnt; i++) {
            val = read_reg(addr + i);
            tx_buf[4 + i*2]     = (unsigned char)(val >> 8);
            tx_buf[4 + i*2 + 1] = (unsigned char)(val & 0xFF);
        }
        /* XOR 校验: 覆盖 4 + data_len 字节 */
        chk = 0;
        for (i = 0; i < 4 + data_len; i++) chk ^= tx_buf[i];
        tx_buf[4 + data_len] = chk;
        send_buf(tx_buf, 5 + data_len);
        return;

    case PCMD_WRITE:
        if (len != 4) { status = PST_ERR; data_len = 0; break; }
        addr = ((unsigned short)tx_buf[3] << 8) | tx_buf[4];
        val  = ((unsigned short)tx_buf[5] << 8) | tx_buf[6];
        if (!write_reg(addr, val)) { status = PST_ERR; data_len = 0; break; }
        /* 回复: 原样回显 */
        tx_buf[0] = mb_addr;
        tx_buf[1] = cmd | 0x80;
        tx_buf[2] = PST_OK;
        tx_buf[3] = 0;  /* 无数据 */
        chk = tx_buf[0] ^ tx_buf[1] ^ tx_buf[2] ^ tx_buf[3];
        tx_buf[4] = chk;
        send_buf(tx_buf, 5);
        return;

    case PCMD_START_CHARGE:
    case PCMD_STOP_CHARGE:
    case PCMD_START_DISCHARGE:
    case PCMD_STOP_DISCHARGE:
    case PCMD_EMERGENCY_STOP:
        write_reg(0x00, cmd);
        status = PST_OK;
        data_len = 0;
        break;

    default:
        status = PST_ERR;
        data_len = 0;
        break;
    }

    /* 通用响应: 状态 */
    tx_buf[0] = mb_addr;
    tx_buf[1] = cmd | 0x80;
    tx_buf[2] = status;
    tx_buf[3] = data_len;
    chk = tx_buf[0] ^ tx_buf[1] ^ tx_buf[2] ^ tx_buf[3];
    tx_buf[4] = chk;
    send_buf(tx_buf, 5);
}


/* ========== 初始化 ========== */
void Protocol_Init(unsigned char addr)
{
    if (addr == 0) {
        unsigned char hw = 0;
        hw |= (ADDR_0) ? 0x01 : 0x00;
        hw |= (ADDR_1) ? 0x02 : 0x00;
        hw |= (ADDR_2) ? 0x04 : 0x00;
        hw |= (ADDR_3) ? 0x08 : 0x00;
        hw |= (ADDR_4) ? 0x10 : 0x00;
        mb_addr = hw + 1;
    } else {
        mb_addr = addr;
    }
    rb_wr = 0;
    rb_count = 0;
    rb_pkt_ready = 0;
}

unsigned char Protocol_GetAddr(void) { return mb_addr; }
