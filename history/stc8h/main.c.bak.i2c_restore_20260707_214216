#define NO_BAT_VOLT_THRESHOLD   5000    // 低于5V判定无电池
#define NO_BAT_CURR_THRESHOLD   300     // 低于300mA判定无电池
#define NO_BAT_CHECK_TIMEOUT_MS 10000   // 自检超时10秒
#define OVER_VOLT_CONFIRM_MS   50000   // 过充确认延时2秒
#define UNDER_VOLT_CONFIRM_MS  50000   // 过放确认延时2秒

// 充电过充延时确认状态
static unsigned long chg_overc_wait_start_tick = 0;
static unsigned char  chg_overc_waiting = 0;      // 0:未等待 1:正在等待确认过充

// 放电过放延时确认状态
static unsigned long dischg_overd_wait_start_tick = 0;
static unsigned char  dischg_overd_waiting = 0;    // 0:未等待 1:正在等待确认过放
	
// ---------- 内部变量 ----------
// 充电完成确认 (3秒消抖)
#define CHG_COMPLETE_CONFIRM_MS  30000
#define DISCHG_COMPLETE_CONFIRM_MS 30000

unsigned long xdata chg_complete_wait_start_tick = 0;
unsigned char xdata chg_complete_waiting = 0;

// 放电完成确认 (3秒消抖)
unsigned long xdata dischg_complete_wait_start_tick = 0;
unsigned char xdata dischg_complete_waiting = 0;

// UART 帧超时恢复 (1秒)
xdata unsigned int curChargeMAH;            // 当前充电mAh
xdata unsigned int curDischargeMAH;         // 当前放电mAh
xdata unsigned int curBatVolt;              // 当前电池电压(mV)
xdata unsigned int overchargeProtectVolt;   // 设置的过充保护电压
xdata unsigned int overdischargeProtectVolt;// 设置的过放保护电压
xdata unsigned int readOverchargeProtectVolt;  // 实测过充保护电压
xdata unsigned int readOverdischargeProtectVolt; // 实测过放保护电压
xdata unsigned char cycleDischargeNum;        // 写入的循环放电次数
xdata unsigned char curCycleNum;              // 当前循环次数
xdata unsigned int cycleDischargeEndMAH[10]; // 10次放电结束mAh
xdata unsigned int cycleChargeEndMAH[10];   // 10次充电结束mAh
xdata unsigned char alarmOvercharge;          // 过充报警位 (bit0)
xdata unsigned char alarmOverdischarge;       // 过放报警位 (bit0)
xdata unsigned char chargeVoltSet;            // 充电电压设置
xdata unsigned char chargeCurrentSet;         // 充电电流设置
xdata unsigned char batteryType;              // 电池类型
xdata unsigned int curChargeCurrentMA;
xdata unsigned int curDischargeCurrentMA;

// ---------- I2C从机状态控制 ----------
xdata unsigned char i2c_cmd;                  // 当前接收的命令
xdata unsigned char i2c_rx_len;               // 需要接收的数据长度（0/1/2）
xdata unsigned char i2c_rx_index;              // 已接收字节数
xdata unsigned char i2c_rx_buf[2];             // 接收数据缓冲区
xdata unsigned char i2c_tx_len;                // 待发送数据长度
xdata unsigned char i2c_tx_index;              // 已发送字节数
xdata unsigned char i2c_tx_buf[3];             // 发送缓冲区
bit i2c_pending_read;              // 等待读请求标志

// ---------- I2C从机请求标志 ----------
bit start_discharge_req = 0;
bit stop_discharge_req  = 0;
bit start_charge_req    = 0;
bit stop_charge_req     = 0;




unsigned long charge_start_tick;   // 进入充电状态时的 tick
unsigned long discharge_start_tick; // 进入放电状态时的 tick

unsigned long init_check_tick = 0; // 自检开始tick
bit init_check_done = 0;       // 开机自检完成
bit no_battery_flag = 0;       // 无电池标志
unsigned int CHG_CURRENT_SET_Pwm;

unsigned char init_check_phase = 0;    // 自检阶段: 0=放电, 1=充电

char data_dat = 0;
// ---------- 状态机 ----------
typedef enum {
    STATE_IDLE,
    STATE_CHARGING,
    STATE_DISCHARGING,
    STATE_CHARGE_COMPLETE,   // 充电完成（电流<10mA），准备切放电
    STATE_DISCHARGE_COMPLETE,// 放电完成，电流<10mA，准备进行充电
    STATE_NO_BATTERY,           // 确认无电池-保持放电等待电池插入
    STATE_INIT_CHECK            // 开机自检-短时充放电检测
} SystemState;

xdata SystemState current_state = STATE_IDLE;
xdata unsigned int charge_start_mah = 0;     // 本次充电起始容量
xdata unsigned int discharge_start_mah = 0;  // 本次放电起始容量

static unsigned long last_print_tick = 0; 

