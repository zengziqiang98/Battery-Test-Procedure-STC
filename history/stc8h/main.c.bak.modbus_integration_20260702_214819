void delay_ms(unsigned int ms)
{
    unsigned long start = TimeStamp_GetTick();
    unsigned long target = (unsigned long)ms * 10;  // 1ms = 10 × 100us
    while ((TimeStamp_GetTick() - start) < target);
}
void SetChargeParamsByBatteryType(void)
{
    // 假设 batteryType 由主机通过 I2C 命令 CMD_SET_BAT_TYPE 写入
    // 具体映射规则需根据实际电池规格定义，以下为示例：
    switch (batteryType) {
        case 0: // 五节三元
            CHG_VOLT_SET_1 = 0;
            CHG_VOLT_SET_2 = 0;   // 假设00对应4.2V
            CHG_CURRENT_SET_Pwm = 100;   // PWM100%，放电1000mA
						PWMA_Duty.PWM1_Duty = 24000;
						overchargeProtectVolt = 22500;
						overdischargeProtectVolt = 12000;
						UpdatePwm(PWMA, &PWMA_Duty);
            break;
        case 1: // 四节三元
            CHG_VOLT_SET_1 = 1;
            CHG_VOLT_SET_2 = 1;   // 假设10对应4.35V
            CHG_CURRENT_SET_Pwm = 50;   // 占空比50%，放电500mA
						PWMA_Duty.PWM1_Duty = 6000;
						overchargeProtectVolt = 18500;
						overdischargeProtectVolt = 9500;
						UpdatePwm(PWMA, &PWMA_Duty);
            break;
        case 2: // 四节铁锂电池
            CHG_VOLT_SET_1 = 1;
            CHG_VOLT_SET_2 = 1;   // 假设10对应4.35V
            CHG_CURRENT_SET_Pwm = 50;   // 占空比50%，放电500mA
						PWMA_Duty.PWM1_Duty = 6000;
						overchargeProtectVolt = 15500;
						overdischargeProtectVolt = 8000;
						UpdatePwm(PWMA, &PWMA_Duty);
            break;
        default:
            CHG_VOLT_SET_1 = 0;
            CHG_VOLT_SET_2 = 0;
            CHG_CURRENT_SET = 1;
            break;
    }
    // 注意：实际硬件需要足够时间稳定，可能需短暂延时
}

void	PWM_config(void)
{
	PWMx_InitDefine		PWMx_InitStructure;
	
	PWMx_InitStructure.PWM_Mode    =	CCMRn_PWM_MODE1;	//模式,		CCMRn_FREEZE,CCMRn_MATCH_VALID,CCMRn_MATCH_INVALID,CCMRn_ROLLOVER,CCMRn_FORCE_INVALID,CCMRn_FORCE_VALID,CCMRn_PWM_MODE1,CCMRn_PWM_MODE2
	PWMx_InitStructure.PWM_Duty    = 1200;	//PWM占空比时间, 0~Period
	PWMx_InitStructure.PWM_EnoSelect   =  ENO1N;	//输出通道选择,	ENO1P,ENO1N,ENO2P,ENO2N,ENO3P,ENO3N,ENO4P,ENO4N / ENO5P,ENO6P,ENO7P,ENO8P
	PWM_Configuration(PWM1, &PWMx_InitStructure);			//初始化PWM,  PWMA,PWMB

	PWMx_InitStructure.PWM_Period   = 24000;					//周期时间,   0~65535
	PWMx_InitStructure.PWM_DeadTime = 0;					//死区发生器设置, 0~255
	PWMx_InitStructure.PWM_MainOutEnable= ENABLE;			//主输出使能, ENABLE,DISABLE
	PWMx_InitStructure.PWM_CEN_Enable   = ENABLE;			//使能计数器, ENABLE,DISABLE
	PWM_Configuration(PWMA, &PWMx_InitStructure);			//初始化PWM通用寄存器,  PWMA,PWMB

	PWM1_SW(PWM1_SW_P20_P21);			//PWM1_SW_P10_P11,PWM1_SW_P20_P21,PWM1_SW_P60_P61


	NVIC_PWM_Init(PWMA,DISABLE,Priority_0);
}

void I2C_config(void)
{
    I2C_InitTypeDef I2C_InitStructure;
    unsigned char slave_addr;
		char addr_buf[32];
    // 1. 配置地址引脚为高阻输入模式（确保外部电平可读取）
    // P2^5, P2^6, P2^7 属于 P2 口
    P2M1 |= 0xE0;      // 设置 P2M1 对应位为 1
    P2M0 &= ~0xE0;     // 设置 P2M0 对应位为 0 => 高阻输入
    // P0^2, P0^3 属于 P0 口
    P0M1 |= 0x0C;      // 设置 P0M1 对应位为 1
    P0M0 &= ~0x0C;     // 设置 P0M0 对应位为 0 => 高阻输入

    // 2. 读取引脚电平并合成从机地址（高两位固定为 11）
    slave_addr  = 0xC0;                     // 高两位固定为 11
    slave_addr |= ((unsigned char)ADDR_4 << 5);  // bit4
    slave_addr |= ((unsigned char)ADDR_3 << 4);  // bit3
    slave_addr |= ((unsigned char)ADDR_2 << 3);  // bit2
    slave_addr |= ((unsigned char)ADDR_1 << 2);  // bit1
    slave_addr |= ((unsigned char)ADDR_0 << 1);                  // bit0

    // 3. 填充 I2C 初始化结构体
    I2C_InitStructure.I2C_Mode      = I2C_Mode_Slave;
    I2C_InitStructure.I2C_Enable    = ENABLE;
    I2C_InitStructure.I2C_SL_MA     = ENABLE;
    I2C_InitStructure.I2C_SL_ADR    = slave_addr >> 1;  // 使用动态计算的地址
    I2C_Init(&I2C_InitStructure);

    // 4. 配置 I2C 中断
    NVIC_I2C_Init(I2C_Mode_Slave, I2C_ESTAI|I2C_ERXI|I2C_ETXI|I2C_ESTOI, Priority_0);

    // 5. 选择 I2C 引脚（根据硬件连接）
    I2C_SW(I2C_P14_P15);  // 默认使用 P2.4/P2.5，但注释说是 P1.4/P1.5，根据实际选择
		
    sprintf(addr_buf, "I2C Slave Address: 0x%02X\r\n", (int)slave_addr >> 1);
    PrintString1((u8*)addr_buf);
}

void	UART_config(void)
{
	COMx_InitDefine		COMx_InitStructure;					//结构定义

	COMx_InitStructure.UART_Mode      = UART_8bit_BRTx;		//模式,   UART_ShiftRight,UART_8bit_BRTx,UART_9bit,UART_9bit_BRTx
	COMx_InitStructure.UART_BRT_Use   = BRT_Timer1;			//选择波特率发生器, BRT_Timer1, BRT_Timer2 (注意: 串口2固定使用BRT_Timer2, 所以不用选择)
	COMx_InitStructure.UART_BaudRate  = 115200ul;			//波特率,     110 ~ 115200
	COMx_InitStructure.UART_RxEnable  = ENABLE;				//接收允许,   ENABLE或DISABLE
	UART_Configuration(UART1, &COMx_InitStructure);		//初始化串口2 USART1,USART2,USART3,USART4
	NVIC_UART1_Init(ENABLE,Priority_1);		//中断使能, ENABLE/DISABLE; 优先级(低到高) Priority_0,Priority_1,Priority_2,Priority_3
	UART1_SW(UART1_SW_P30_P31);	//通道切换，选择P3.0, P3.1引脚通信
}
void XOSC_Init() {
    // 1. 使能访问XFR（扩展特殊功能寄存器）
    P_SW2 |= 0x80;
    
    // 2. 启动外部晶振（高速）
    XOSCCR = 0xC0; // 0xC0: 使能外部晶振，无源晶振模式
    // 如果使用32.768KHz低速晶振，应使用：X32KCR = 0x80 + 0x40; // 启动+高增益
    // 2.1 等待时钟稳定
    while (!(XOSCCR & 0x01)); // 等待XOSCCR的bit0被硬件置1
    
    // 3. 选择外部晶振作为系统时钟源
    CLKDIV = 0x00;    // 时钟不分频
    CLKSEL = 0x01;    // 选择外部晶振
    
    // 4. 关闭内部高速IRC以省电（可选）
    // HIRCCR &= 0x7F;
    
    // 恢复XFR访问权限
//    P_SW2 &= 0x7F;
}

// ---------- 主函数 ----------
void main(void)
{
		unsigned char wr;
		unsigned char ch;
	// 初始化IO
    EAXSFR();
		XOSC_Init();
    // P1.0和P1.1在GPIO_config中已配置，但为确保，可再次确认
    // 控制引脚默认低电平（关闭）
		
    CHARGE_CTRL = 0;
    DISCHARGE_CTRL = 0;
    FAN_CTRL = 0;
	
	//	EA = 1;

    // 初始化变量
    charge_capacity_num = 0;
    discharge_capacity_num = 0;
		discharge_capacity_int = 0;
		discharge_capacity_frac = 0;
		charge_capacity_int = 0;
		charge_capacity_frac = 0;
    curBatVolt = 0;
    overchargeProtectVolt = 21000; // 默认4.2V
    overdischargeProtectVolt = 16000;
    readOverchargeProtectVolt = 0;
    readOverdischargeProtectVolt = 0;
    cycleDischargeNum = 1;          // 默认循环1次
    curCycleNum = 0;
    alarmOvercharge = 0;
    alarmOverdischarge = 0;
    memset(cycleDischargeEndMAH, 0, sizeof(cycleDischargeEndMAH));
    memset(cycleChargeEndMAH, 0, sizeof(cycleChargeEndMAH));
    chargeVoltSet = 0;
    chargeCurrentSet = 0;
    batteryType = 0;
		charge_start_tick = 0;
		discharge_start_tick = 0;
		adc_bat_code = 0;
    // 初始化外设
		EA = 1; 
		GPIO_config();
		UART_config();
    I2C_config();
    
    ADC_config();

    TimeStamp_Init();   // 启动100us定时器，用于容量积分
    Capacity_Init();    // 容量积分初始化
		PWM_config();
                // 开启总中断
		printf("STC8H8K64U UART1 Test Programme!\r\n");	//UART1发送一个字符串	
    // 主循环
    alarmOvercharge = 0;
    alarmOverdischarge = 0;
    while (1)
    {
//			printf("cmd = %d",(int)data_dat);

        // ===== 开机无电池自检 =====
        if (!init_check_done)
        {
            init_check_done = 1;
            if (current_state == STATE_IDLE)
            {
                // 第一步：短暂放电，看电压是否立即掉到5V以下
                curCycleNum = 0;
                alarmOverdischarge &= ~(ALARM_OVERDISCHARGE_BIT | ALARM_DISCHARGE_COMPLETE_BIT);
                alarmOverdischarge |= ALARM_DISCHARGING_BIT;
                alarmOvercharge &= ~(ALARM_OVERCHARGE_BIT | ALARM_CHARGE_COMPLETE_BIT | ALARM_CHARGING_BIT);
                discharge_capacity_num = 0;
                discharge_capacity_int = 0;
                discharge_capacity_frac = 0;
                DISCHARGE_CTRL = 1;
                // 自检期间不转风扇
                current_state = STATE_INIT_CHECK;
                init_check_tick = TimeStamp_GetTick();
                init_check_phase = 0;  // 0=放电检测, 1=充电检测
            }
        }

				I2C_ProcessCommandFeedback();

				// UART帧超时恢复 (1秒无数据则重置)
				if (uart_rx_state == 1 && (TimeStamp_GetTick() - uart_rx_timeout_tick > 10000)) {
					uart_rx_state = 0;
				}//				printf("STC8H8K64U UART1 Test Programme!\r\n");	//UART1发送一个字符串
//				printf("time:%d\r\n",last_print_tick);	//UART1发送一个字符串
				wr = COM1.RX_Cnt;   /* 获取当前写指针 */
				while (uart_rx_rd != wr && 1) {
					ch = RX1_Buffer[uart_rx_rd];
					uart_rx_rd++;
					if (uart_rx_rd >= COM_RX1_Lenth) uart_rx_rd = 0;

					if (uart_rx_state == 0) {
							/* 等待命令字节 */
							uart_cmd = ch;
							/* 根据命令确定后续数据长度 */
							switch (uart_cmd) {
									case CMD_SET_OVERC_PROT_VOLT:
									case CMD_SET_OVERD_PROT_VOLT:
											uart_data_len = 2;
											uart_rx_state = 1;
											uart_data_idx = 0;
											break;
									case CMD_SET_CYCLE_DISCH_NUM:
									case CMD_SET_CHARGE_VOLT:
									case CMD_SET_CHARGE_CURRENT:
									case CMD_SET_BAT_TYPE:
											uart_data_len = 1;
											uart_rx_state = 1;
											uart_data_idx = 0;
											break;
									default:
											/* 无数据命令立即执行 */
											execute_uart_command(uart_cmd, NULL, 0);
											break;
							}
					} else {
							/* 接收数据字节 */
							if (uart_data_idx < uart_data_len) {
									uart_data_buf[uart_data_idx++] = ch;
							}
							if (uart_data_idx >= uart_data_len) {
									/* 数据收齐，执行命令 */
									execute_uart_command(uart_cmd, uart_data_buf, uart_data_len);
									uart_rx_state = 0;   /* 回到等待命令状态 */
							}
					}
			}
        // 更新容量和电压（由定时器驱动，每100ms积分一次）
        Capacity_Update();

        // 处理停止请求（优先）
        if (stop_discharge_req)
        {
            stop_discharge_req = 0;
            if (current_state == STATE_DISCHARGING || current_state == STATE_DISCHARGE_COMPLETE)
            {
                DISCHARGE_CTRL = 0;
                FAN_CTRL = 0;
                alarmOvercharge &= ~(ALARM_CHARGING_BIT | ALARM_CHARGE_COMPLETE_BIT);
                discharge_capacity_num = 0;
                discharge_capacity_int = 0;
                discharge_capacity_frac = 0;
                alarmOvercharge = 0;
                alarmOverdischarge = 0;
                current_state = STATE_IDLE;
            }
        }

        if (stop_charge_req)
        {
            stop_charge_req = 0;
            if (current_state == STATE_CHARGING || current_state == STATE_CHARGE_COMPLETE)
            {
                CHARGE_CTRL = 0;
                alarmOverdischarge &= ~(ALARM_DISCHARGING_BIT | ALARM_DISCHARGE_COMPLETE_BIT);
                charge_capacity_num = 0;
                charge_capacity_int = 0;
                charge_capacity_frac = 0;
                alarmOvercharge = 0;
                alarmOverdischarge = 0;
                current_state = STATE_IDLE;
            }
        }

        // 处理开始请求
        if (start_charge_req) {
						start_charge_req = 0;
						if (current_state == STATE_IDLE) {
								curCycleNum = 0;
                                // 复位充电相关报警和状态标志
								alarmOvercharge &= ~(ALARM_OVERCHARGE_BIT | ALARM_CHARGE_COMPLETE_BIT);
                                alarmOvercharge |= ALARM_CHARGING_BIT;   // 置位正在充电
                                alarmOverdischarge &= ~(ALARM_OVERDISCHARGE_BIT | ALARM_DISCHARGE_COMPLETE_BIT | ALARM_DISCHARGING_BIT);
								if (cycleDischargeNum == 0) cycleDischargeNum = 1;
								charge_capacity_num = 0;                     // 清零累计容量
								charge_capacity_int = 0;
								charge_capacity_frac = 0;
								SetChargeParamsByBatteryType();
								CHARGE_CTRL = 1;
								CHG_CURRENT_SET = 1;
								current_state = STATE_CHARGING;
								charge_start_tick = TimeStamp_GetTick();
						}
				}

				if (start_discharge_req) {
						start_discharge_req = 0;
						if (current_state == STATE_IDLE) {
								curCycleNum = 0;
								 // 复位放电相关标志，同时清除充电相关标志（确保退出充电状态）
                                alarmOverdischarge &= ~(ALARM_OVERDISCHARGE_BIT | ALARM_DISCHARGE_COMPLETE_BIT);
                                alarmOverdischarge |= ALARM_DISCHARGING_BIT;
                                alarmOvercharge &= ~(ALARM_OVERCHARGE_BIT | ALARM_CHARGE_COMPLETE_BIT | ALARM_CHARGING_BIT);
								if (cycleDischargeNum == 0) cycleDischargeNum = 1;
								discharge_capacity_num = 0;                  // 清零累计容量
								discharge_capacity_int = 0;
								discharge_capacity_frac = 0;
								FAN_CTRL = 1;
								DISCHARGE_CTRL = 1;
								current_state = STATE_DISCHARGING;
								discharge_start_tick = TimeStamp_GetTick();
						}
				}
				Capacity_Update();
        // 状态机处理
				
        switch (current_state)
				{
					case STATE_IDLE:
							CHG_LED = 0;
							DISCHG_LED = 0;
							chg_overc_waiting = 0;
							dischg_overd_waiting = 0;
							curCycleNum = 0;
                            alarmOvercharge &= ~ALARM_CHARGING_BIT;
                            alarmOverdischarge &= ~ALARM_DISCHARGING_BIT;
							memset(cycleDischargeEndMAH, 0, sizeof(cycleDischargeEndMAH));
							memset(cycleChargeEndMAH, 0, sizeof(cycleChargeEndMAH));
					break;
						case STATE_CHARGING:
									CHG_LED = 1;
									DISCHG_LED = 0;

									// 充电启动稳定期：开始后50秒内不进行过充和正常结束检测
									if ((TimeStamp_GetTick() - charge_start_tick) < 50000) {
											break;
									}

									// ----- 过充检测及延时确认 -----
									if (curBatVolt >= overchargeProtectVolt && curChargeCurrentMA > 300) {
											if (!chg_overc_waiting) {
													// 首次检测到过充条件，开始延时确认
													chg_overc_waiting = 1;
													chg_overc_wait_start_tick = TimeStamp_GetTick();
											} else {
													// 已在等待确认，检查是否到达延时时间
													if ((TimeStamp_GetTick() - chg_overc_wait_start_tick) >= OVER_VOLT_CONFIRM_MS) {
															// 延时到达，再次确认条件是否仍满足
															if (curBatVolt >= overchargeProtectVolt && curChargeCurrentMA > 300) {
																	// 确认过充，执行保护动作
																	 // 确认过充
                                                                    alarmOvercharge |= ALARM_OVERCHARGE_BIT;      // 置位过充报警
                                                                    alarmOvercharge &= ~(ALARM_CHARGING_BIT | ALARM_CHARGE_COMPLETE_BIT); // 清除正在充电和充满标志
                                                                    alarmOverdischarge &= ~(ALARM_DISCHARGING_BIT | ALARM_DISCHARGE_COMPLETE_BIT);
																	readOverchargeProtectVolt = curBatVolt;
																	CHARGE_CTRL = 0;
																	charge_capacity_num = 0;
																	charge_capacity_int = 0;
																	charge_capacity_frac = 0;
																	current_state = STATE_IDLE;
																	chg_overc_waiting = 0;
																	break;   // 退出switch，终止本次循环
															} else {
																	// 假信号，清除等待标志
																	chg_overc_waiting = 0;
															}
													}
											}
									} else {
											// 当前不满足过充条件，若正在等待则取消等待（假信号提前消失）
											if (chg_overc_waiting) {
													chg_overc_waiting = 0;
											}
									}

									// ----- // ----- 正常充电结束检测（电流 ≤ 150mA，连续3秒确认）-----
									if (curChargeCurrentMA <= 300) {
											if (!chg_complete_waiting) {
													// 第一次检测，开始3秒确认
													chg_complete_waiting = 1;
													chg_complete_wait_start_tick = TimeStamp_GetTick();
											} else if ((TimeStamp_GetTick() - chg_complete_wait_start_tick) >= CHG_COMPLETE_CONFIRM_MS) {
													// 3秒确认完成
													if (chg_overc_waiting) {
															chg_overc_waiting = 0;
													}
													CHARGE_CTRL = 0;
													cycleChargeEndMAH[curCycleNum] = curChargeMAH;
                                            // 清除正在充电标志
                                            alarmOvercharge &= ~ALARM_CHARGING_BIT;
                                            alarmOvercharge |= ALARM_CHARGE_COMPLETE_BIT;
													charge_capacity_num = 0;
													charge_capacity_int = 0;
													charge_capacity_frac = 0;
													current_state = STATE_CHARGE_COMPLETE;
													chg_complete_waiting = 0;
											}
									} else {
											// 条件消失，清除等待
											chg_complete_waiting = 0;
									}
									break;

						case STATE_DISCHARGING:
									CHG_LED = 0;
									DISCHG_LED = 1;

									// 放电启动稳定期：开始后50秒内不进行过放和正常结束检测
									if ((TimeStamp_GetTick() - discharge_start_tick) < 50000) {
											break;
									}

									// ----- 过放检测及延时确认 -----
									if (curBatVolt <= overdischargeProtectVolt && curDischargeCurrentMA > 300) {
											if (!dischg_overd_waiting) {
													// 首次检测到过放条件，开始延时确认
													dischg_overd_waiting = 1;
													dischg_overd_wait_start_tick = TimeStamp_GetTick();
											} else {
													// 已在等待确认，检查是否到达延时时间
													if ((TimeStamp_GetTick() - dischg_overd_wait_start_tick) >= UNDER_VOLT_CONFIRM_MS) {
															// 延时到达，再次确认条件是否仍满足
															if (curBatVolt <= overdischargeProtectVolt && curDischargeCurrentMA > 300 && curBatVolt >= 500) {
																	// 确认过放
                                                                    alarmOverdischarge |= ALARM_OVERDISCHARGE_BIT;
                                                                    alarmOverdischarge &= ~(ALARM_DISCHARGING_BIT | ALARM_DISCHARGE_COMPLETE_BIT);
                                                                    alarmOvercharge &= ~(ALARM_CHARGING_BIT | ALARM_CHARGE_COMPLETE_BIT);
																	readOverdischargeProtectVolt = curBatVolt;
																	DISCHARGE_CTRL = 0;
																	FAN_CTRL = 0;
																	discharge_capacity_num = 0;
																	discharge_capacity_int = 0;
																	discharge_capacity_frac = 0;
																	current_state = STATE_IDLE;
																	dischg_overd_waiting = 0;
																	break;   // 退出switch，终止本次循环
															} else {
																	// 假信号，清除等待标志
																	dischg_overd_waiting = 0;
															}
													}
											}
									} else {
											// 当前不满足过放条件，若正在等待则取消等待（假信号提前消失）
											if (dischg_overd_waiting) {
													dischg_overd_waiting = 0;
											}
									}

									// ----- // ----- 正常放电结束检测（电流 ≤ 150mA，连续3秒确认）-----
									if (curDischargeCurrentMA <= 300) {
											if (!dischg_complete_waiting) {
													// 第一次检测，开始3秒确认
													dischg_complete_waiting = 1;
													dischg_complete_wait_start_tick = TimeStamp_GetTick();
											} else if ((TimeStamp_GetTick() - dischg_complete_wait_start_tick) >= DISCHG_COMPLETE_CONFIRM_MS) {
													// 3秒确认完成
													if (dischg_overd_waiting) {
															dischg_overd_waiting = 0;
													}
													DISCHARGE_CTRL = 0;
													FAN_CTRL = 0;
													cycleDischargeEndMAH[curCycleNum] = curDischargeMAH;
                                            alarmOverdischarge &= ~ALARM_DISCHARGING_BIT;
                                            alarmOverdischarge |= ALARM_DISCHARGE_COMPLETE_BIT;
													discharge_capacity_num = 0;
													discharge_capacity_int = 0;
													discharge_capacity_frac = 0;
													current_state = STATE_DISCHARGE_COMPLETE;
													dischg_complete_waiting = 0;
											}
									} else {
											// 条件消失，清除等待
											dischg_complete_waiting = 0;
									}
									break;


        case STATE_INIT_CHECK:
            CHG_LED = 0;
            DISCHG_LED = 1;
            FAN_CTRL = 0;  // 自检期间关闭风扇
            if (init_check_phase == 0) {
                /* 阶段0：放电检测 - 等待1秒看电压/电流 */
                if ((TimeStamp_GetTick() - init_check_tick) >= 50000) {
                    /* 2秒后检查 */
                    if (curBatVolt < NO_BAT_VOLT_THRESHOLD && curDischargeCurrentMA < NO_BAT_CURR_THRESHOLD) {
                        /* 电压<5V且无电流 → 疑似无电池，进入充电验证 */
                        DISCHARGE_CTRL = 0;
                        alarmOverdischarge &= ~(ALARM_DISCHARGING_BIT | ALARM_DISCHARGE_COMPLETE_BIT);
                        alarmOvercharge |= ALARM_CHARGING_BIT;
                        charge_capacity_num = 0;
                        charge_capacity_int = 0;
                        charge_capacity_frac = 0;
                        SetChargeParamsByBatteryType();
                        CHARGE_CTRL = 1;
                        CHG_CURRENT_SET = 1;
                        init_check_phase = 1;
                        init_check_tick = TimeStamp_GetTick();
                        CHG_LED = 1;
                    } else {
                        /* 电压正常或有电流 → 真电池 → IDLE */
                        DISCHARGE_CTRL = 0;
                        alarmOverdischarge &= ~(ALARM_DISCHARGING_BIT | ALARM_DISCHARGE_COMPLETE_BIT);
                        current_state = STATE_IDLE;
                    }
                }
            } else {
                /* 阶段1：充电检测 - 检查电流能否达到300mA */
                delay_ms(5000);
                if (curChargeCurrentMA >= NO_BAT_CURR_THRESHOLD) {
                    /* 有充电电流 → 真电池（只是没电）→ IDLE */
                    
                    CHARGE_CTRL = 0;
                    alarmOvercharge &= ~ALARM_CHARGING_BIT;
                    current_state = STATE_IDLE;
                } else if ((TimeStamp_GetTick() - init_check_tick) >= NO_BAT_CHECK_TIMEOUT_MS) {
                    /* 10秒超时，电流始终<300mA → 确认无电池 */
                    CHARGE_CTRL = 0;
                    alarmOvercharge &= ~(ALARM_CHARGING_BIT | ALARM_CHARGE_COMPLETE_BIT);
                    alarmOverdischarge &= ~(ALARM_OVERDISCHARGE_BIT | ALARM_DISCHARGE_COMPLETE_BIT | ALARM_DISCHARGING_BIT);
                    /* 进入无电池状态: 保持放电，等待电池插入 */
                    no_battery_flag = 1;
                    alarmOvercharge |= ALARM_NO_BATTERY_BIT;  // 上报无电池
                    alarmOverdischarge |= ALARM_DISCHARGING_BIT;
                    DISCHARGE_CTRL = 1;
                    current_state = STATE_NO_BATTERY;
                }
            }
            break;

        case STATE_NO_BATTERY:
            CHG_LED = 0;
            DISCHG_LED = 1;
            FAN_CTRL = 0;  // 无电池状态不转风扇
            DISCHARGE_CTRL = 1;
            alarmOverdischarge |= ALARM_DISCHARGING_BIT;
            
            /* 检测电池插入: 电压回升到5V以上 */
            if (curBatVolt >= NO_BAT_VOLT_THRESHOLD) {
                no_battery_flag = 0;
                alarmOvercharge &= ~ALARM_NO_BATTERY_BIT;  // 清除无电池标志
                DISCHARGE_CTRL = 0;
                alarmOverdischarge &= ~(ALARM_DISCHARGING_BIT | ALARM_DISCHARGE_COMPLETE_BIT);
                alarmOvercharge &= ~(ALARM_OVERCHARGE_BIT | ALARM_CHARGE_COMPLETE_BIT | ALARM_CHARGING_BIT);
                current_state = STATE_IDLE;
            }
            break;

            case STATE_CHARGE_COMPLETE:
                 // 充电完成，不再自动放电
                alarmOvercharge &= ~ALARM_CHARGING_BIT;
                alarmOvercharge |= ALARM_CHARGE_COMPLETE_BIT;
                // (注：bit0 保留给过充报警，bit1 表示正常充满)
                CHARGE_CTRL = 0;              // 关闭充电开关
                cycleChargeEndMAH[curCycleNum] = curChargeMAH;  // 记录本次充电容量
                charge_capacity_int = 0;
                charge_capacity_frac = 0;
                current_state = STATE_IDLE;   // 回到空闲状态
                break;

            case STATE_DISCHARGE_COMPLETE:
                 // 放电完成，不再自动充电，循环次数计数器也不增加
                alarmOverdischarge &= ~ALARM_DISCHARGING_BIT;
                alarmOverdischarge |= ALARM_DISCHARGE_COMPLETE_BIT;
                // (注：bit0 保留给过放报警，bit1 表示正常放完)
                DISCHARGE_CTRL = 0;
                FAN_CTRL = 0;                 // 关闭风扇
                cycleDischargeEndMAH[curCycleNum] = curDischargeMAH; // 记录本次放电容量
                discharge_capacity_int = 0;
                discharge_capacity_frac = 0;
                current_state = STATE_IDLE;
                break;

            default:
                break;
        }
				if ((TimeStamp_GetTick() - last_print_tick) >= 10000)  // 100us * 10000 = 1秒
				{
						char print_buf[128];   // 足够容纳所有数据

						// 格式化所有数据（可根据需要调整格式）
						sprintf(print_buf,
								"\r\n===== System Data =====\r\n"
								"BatVolt: %umV\r\n"
								"ChgCurr: %umA, DisChgCurr: %umA\r\n"
								"ChgCap: %umAh, DisChgCap: %umAh\r\n"
								"OvChgProt: %umV, OvDisProt: %umV\r\n"
								"Cycle: %u/%u\r\n"
								"AlarmOvChg: %u, AlarmOvDis: %u\r\n"
								"BatType: %u, ChgVoltSet: %u, ChgCurrSet: %u\r\n"
								"state = %d\r\n"
								"=======================\r\n",
								curBatVolt,
								curChargeCurrentMA, curDischargeCurrentMA,
								curChargeMAH, curDischargeMAH,
								overchargeProtectVolt, overdischargeProtectVolt,
								curCycleNum, cycleDischargeNum,
								alarmOvercharge, alarmOverdischarge,
								batteryType, chargeVoltSet, chargeCurrentSet,
								current_state
						);

						PrintString1((u8*)print_buf);   // 通过串口1发送
						last_print_tick = TimeStamp_GetTick();
						printf("adc_bat_code = %d\r\n",adc_bat_code);
				}
			
				
        // 可加入短延时，避免循环过紧
         NOP10();
				
    }
		
		
}

/* 执行串口命令并发送响应 */
void execute_uart_command(unsigned char cmd, unsigned char *rxData, unsigned char len)
{
    char response[4];
    char resp_len = 0;
    unsigned int val;
    char i;

    /* 处理带索引的循环容量读取（命令范围 0x10~0x19, 0x1A~0x23） */
    if (cmd >= CMD_CYCLE_DISCH_END_MAH_1 && cmd <= CMD_CYCLE_DISCH_END_MAH_1 + 9) {
        i = cmd - CMD_CYCLE_DISCH_END_MAH_1;
        if (i < 10) {
            val = cycleDischargeEndMAH[i];
            response[0] = (u8)(val >> 8);
            response[1] = (u8)(val & 0xFF);
            resp_len = 2;
        } else {
            response[0] = 0xFF;   /* 索引错误 */
            resp_len = 1;
        }
    }
    else if (cmd >= CMD_CYCLE_CHARGE_END_MAH_1 && cmd <= CMD_CYCLE_CHARGE_END_MAH_1 + 9) {
        i = cmd - CMD_CYCLE_CHARGE_END_MAH_1;
        if (i < 10) {
            val = cycleChargeEndMAH[i];
            response[0] = (u8)(val >> 8);
            response[1] = (u8)(val & 0xFF);
            resp_len = 2;
        } else {
            response[0] = 0xFF;
            resp_len = 1;
        }
    }
    else {
        /* 其他命令 */
        switch (cmd) {
            /* 无数据命令（控制类） */
            case CMD_START_DISCHARGE:
                start_discharge_req = 1;
                response[0] = 0x01;  /* 成功 */
                resp_len = 1;
                break;
            case CMD_STOP_DISCHARGE:
                stop_discharge_req = 1;
                response[0] = 0x02;
                resp_len = 1;
                break;
            case CMD_START_CHARGE:
                start_charge_req = 1;
                response[0] = 0x03;
                resp_len = 1;
                break;
            case CMD_STOP_CHARGE:
                stop_charge_req = 1;
                response[0] = 0x04;
                resp_len = 1;
                break;

            /* 读单字节命令 */
            case CMD_ALARM_OVERCHARGE:
                response[0] = alarmOvercharge;
                resp_len = 1;
                break;
            case CMD_ALARM_OVERDISCHARGE:
                response[0] = alarmOverdischarge;
                resp_len = 1;
                break;
            case CMD_CUR_CYCLE_NUM:
                response[0] = curCycleNum;
                resp_len = 1;
                break;

            /* 读双字节命令 */
            case CMD_CUR_CHARGE_MAH:
                response[0] = (u8)(curChargeMAH >> 8);
                response[1] = (u8)(curChargeMAH & 0xFF);
                resp_len = 2;
                break;
            case CMD_CUR_DISCHARGE_MAH:
                response[0] = (u8)(curDischargeMAH >> 8);
                response[1] = (u8)(curDischargeMAH & 0xFF);
                resp_len = 2;
                break;
            case CMD_CUR_BAT_VOLT:
            case CMD_READ_BAT_VOLT:
                response[0] = (u8)(curBatVolt >> 8);
                response[1] = (u8)(curBatVolt & 0xFF);
                resp_len = 2;
                break;
            case CMD_READ_OVERC_PROT_VOLT:
                response[0] = (u8)(readOverchargeProtectVolt >> 8);
                response[1] = (u8)(readOverchargeProtectVolt & 0xFF);
                resp_len = 2;
                break;
            case CMD_READ_OVERD_PROT_VOLT:
                response[0] = (u8)(readOverdischargeProtectVolt >> 8);
                response[1] = (u8)(readOverdischargeProtectVolt & 0xFF);
                resp_len = 2;
                break;
            case CMD_CUR_CHARGE_CURRENT:
                response[0] = (u8)(curChargeCurrentMA >> 8);
                response[1] = (u8)(curChargeCurrentMA & 0xFF);
                resp_len = 2;
                break;
            case CMD_CUR_DISCHARGE_CURRENT:
                response[0] = (u8)(curDischargeCurrentMA >> 8);
                response[1] = (u8)(curDischargeCurrentMA & 0xFF);
                resp_len = 2;
                break;

            /* 写命令（带数据） */
            case CMD_SET_OVERC_PROT_VOLT:
                if (len == 2) {
                    overchargeProtectVolt = ((u16)rxData[0] << 8) | rxData[1];
                    response[0] = 0x00;
                } else {
                    response[0] = 0xFF;  /* 长度错误 */
                }
                resp_len = 1;
                break;
            case CMD_SET_OVERD_PROT_VOLT:
                if (len == 2) {
                    overdischargeProtectVolt = ((u16)rxData[0] << 8) | rxData[1];
                    response[0] = 0x00;
                } else {
                    response[0] = 0xFF;
                }
                resp_len = 1;
                break;
            case CMD_SET_CYCLE_DISCH_NUM:
                if (len == 1) {
                    cycleDischargeNum = rxData[0];
                    response[0] = 0x00;
                } else {
                    response[0] = 0xFF;
                }
                resp_len = 1;
                break;
            case CMD_SET_CHARGE_VOLT:
                if (len == 1) {
                    chargeVoltSet = rxData[0];
                    /* 控制硬件引脚 */
                    CHG_VOLT_SET_1 = (chargeVoltSet & 0x01) ? 1 : 0;
                    CHG_VOLT_SET_2 = (chargeVoltSet & 0x02) ? 1 : 0;
                    response[0] = 0x00;
                } else {
                    response[0] = 0xFF;
                }
                resp_len = 1;
                break;
            case CMD_SET_CHARGE_CURRENT:
                if (len == 1) {
                    chargeCurrentSet = rxData[0];
                    CHG_CURRENT_SET = 1; /* 简单开关 */
                    response[0] = 0x00;
                } else {
                    response[0] = 0xFF;
                }
                resp_len = 1;
                break;
            case CMD_SET_BAT_TYPE:
                if (len == 1) {
                    batteryType = rxData[0];
										SetChargeParamsByBatteryType();
                    /* 可根据电池类型设置充电参数，此处仅存储 */
                    response[0] = 0x00;
                } else {
                    response[0] = 0xFF;
                }
                resp_len = 1;
                break;

            default:
                response[0] = 0xFF;  /* 未知命令 */
                resp_len = 1;
                break;
        }
    }

    /* 发送响应数据 */
    if (resp_len > 0) {
        for (i = 0; i < resp_len; i++) {
            TX1_write2buff(response[i]);
        }
    }
}

void I2C_ProcessCommandFeedback(void)
{
    if (i2c_last_cmd != 0)
    {
        // 根据命令码输出不同信息
        switch (i2c_last_cmd)
        {
            case CMD_START_DISCHARGE:
                printf("CMD: START_DISCHARGE executed\r\n");
                break;
            case CMD_STOP_DISCHARGE:
                printf("CMD: STOP_DISCHARGE executed\r\n");
                break;
            case CMD_START_CHARGE:
                printf("CMD: START_CHARGE executed\r\n");
                break;
            case CMD_STOP_CHARGE:
                printf("CMD: STOP_CHARGE executed\r\n");
                break;
            case CMD_SET_OVERC_PROT_VOLT:
                printf("CMD: SET_OVERC_PROT_VOLT = %u mV\r\n", overchargeProtectVolt);
                break;
            case CMD_SET_OVERD_PROT_VOLT:
                printf("CMD: SET_OVERD_PROT_VOLT = %u mV\r\n", overdischargeProtectVolt);
                break;
            case CMD_SET_CHARGE_VOLT:
                printf("CMD: SET_CHARGE_VOLT = 0x%02X\r\n", chargeVoltSet);
                break;
            case CMD_SET_CHARGE_CURRENT:
                printf("CMD: SET_CHARGE_CURRENT = 0x%02X\r\n", chargeCurrentSet);
                break;
            case CMD_SET_BAT_TYPE:
                printf("CMD: SET_BAT_TYPE = 0x%02X\r\n", batteryType);
                break;
            // 可添加更多命令的处理...
            default:
                printf("CMD: 0x%02X executed\r\n", i2c_last_cmd);
                break;
        }
        i2c_last_cmd = 0;   // 清除记录，防止重复输出
    }
}